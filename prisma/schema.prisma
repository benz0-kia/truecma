generator client {
  provider = "prisma-client-js"
  output   = "../prisma/generated/client"
}

datasource db {
  provider = "postgresql"
}

model SoldListing {
  id              Int      @id @default(autoincrement())
  mlsId           String   @unique
  address         String
  city            String?
  zip             String?
  beds            Float?
  baths           Float?
  sqft            Float?
  lotSize         Float?
  yearBuilt       Int?
  garageSpaces    Int?
  closePrice      Float?
  listPrice       Float?
  closeDate       String?
  daysOnMarket    Int?
  subdivision     String?
  latitude        Float?
  longitude       Float?
  publicRemarks   String?
  conditionSignal String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SyncLog {
  id               Int       @id @default(autoincrement())
  type             String    // "historical" | "nightly"
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  recordsProcessed Int       @default(0)
  status           String    @default("running") // "running" | "completed" | "failed"
  error            String?
  rangeStart       String?
  rangeEnd         String?
}
